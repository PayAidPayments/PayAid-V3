# =============================================================================
# PayAid V3 – Environment template (copy to .env.local for dev, set in Vercel for prod)
# Phase 1: Prod-ready – REDIS=Upstash, AI=cloud-only or feature-flagged off in prod
# =============================================================================

# --- Required (validated at startup) ---
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
# Required by prisma/schema.prisma `directUrl`. Use the same string as DATABASE_URL for local Postgres.
# Supabase: DATABASE_URL = pooler; DATABASE_DIRECT_URL = direct session connection (dashboard “URI”, port 5432).
DATABASE_DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Production: use Upstash Redis (https://upstash.com – free tier). Never use localhost in prod.
# Cache + optional Bull queues (Bull uses TCP URL; cache can use REST vars below).
REDIS_URL=""
# Upstash REST (recommended for serverless cache – no connection pooling issues)
# Get from Upstash Console → your Redis → REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# For Bull queues in prod: set REDIS_URL to Upstash TCP URL (same DB gives both REST + TCP in console)

# Optional: Prisma Accelerate (connection pool + cache for read-heavy queries)
# ACCELERATE_URL="prisma://accelerate.prisma-data.net/?api_key=..."

JWT_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- AI / TTS (production: leave unset or use cloud-only to avoid demo hangs) ---
# In production: do NOT set to localhost. Use cloud providers or leave unset (fallback to text-only).
# AI_GATEWAY_URL=                    # Prod: unset. Dev: http://localhost:8000 if running gateway
# USE_AI_GATEWAY=                    # Prod: false. Dev: true if using local TTS/STT
# OLLAMA_BASE_URL=                   # Prod: unset. Dev: http://localhost:11434
# TEXT_TO_SPEECH_URL=                # Prod: unset. Dev: http://localhost:7861 (Coqui)
# SPEECH_TO_TEXT_URL=                # Prod: unset. Dev: http://localhost:7862

# Cloud AI (no localhost)
# GROQ_API_KEY=                      # https://console.groq.com/keys
# OPENAI_API_KEY=                    # Optional
# Hugging Face Inference (Marketing image gen). 401 = bad/missing token; put key in repo root .env and restart dev.
# HUGGINGFACE_API_KEY=hf_...         # https://huggingface.co/settings/tokens — Read is enough
# HUGGINGFACE_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# Optional SDXL tuning: HUGGINGFACE_IMAGE_GUIDANCE_SCALE=7.5  HUGGINGFACE_IMAGE_NUM_INFERENCE_STEPS=30
# AI_IMAGE_PROVIDER=auto             # auto | huggingface | worker | comfy

# --- Optional ---
SUPABASE_URL=""
SUPABASE_KEY=""
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
VERCEL=""

# --- Performance testing (Playwright + k6) ---
# Used by: npm run perf:*
PERF_TEST_EMAIL=""
PERF_TEST_PASSWORD=""
PERF_BASE_URL="http://127.0.0.1:3000"
PERF_TENANT_ID="demo-business-pvt-ltd"
PERF_API_TOKEN=""

# --- PayAid Social (standalone app + worker) ---
# When running apps/social on port 3005, point to dashboard API for Studio launch (POST /api/social/posts)
# NEXT_PUBLIC_SOCIAL_API_URL="http://localhost:3000"
# Social-post-dispatch worker uses REDIS_URL + DATABASE_URL (same as dashboard). Run: npm run worker:social-dispatch

# --- AI Image generation (server-side) ---
# Select provider: auto | huggingface | a1111 | worker | comfy
AI_IMAGE_PROVIDER=auto

# Option A (self-hosted): Automatic1111 WebUI (A1111)
# Run A1111 separately and point PayAid at it:
# A1111_URL="http://127.0.0.1:7860"
# Optional (only if your reverse-proxy expects a Bearer token):
# A1111_API_KEY=""
# Optional request timeout (ms):
# A1111_TIMEOUT_MS=300000

# Option B (self-hosted): PayAid text-to-image worker (services/text-to-image) — used first when set (Marketing Studio “Auto” or “PayAid Image Generator only”).
# Run: cd services/text-to-image && pip install -r requirements.txt && python server.py  → default http://127.0.0.1:7860
# IMAGE_WORKER_URL="http://127.0.0.1:7860"
# TEXT_TO_IMAGE_SERVICE_URL=              # legacy alias for IMAGE_WORKER_URL
# IMAGE_WORKER_FETCH_TIMEOUT_MS=900000

# Option C (cloud): Hugging Face Inference API
# HUGGINGFACE_API_KEY="hf_..."
# HUGGINGFACE_IMAGE_MODEL="stabilityai/stable-diffusion-xl-base-1.0"
# Optional inpaint model (used when mode=inpaint):
# HUGGINGFACE_INPAINT_MODEL="runwayml/stable-diffusion-inpainting"
# HUGGINGFACE_IMAGE_TIMEOUT_MS=180000

# Optional: image realism QA gate (recommended for checkout/payment creatives)
# PAYAID_IMAGE_QA_GATE_ENABLED=true
# PAYAID_IMAGE_QA_MAX_ATTEMPTS=3
# PAYAID_IMAGE_QA_CANDIDATES=4
# PAYAID_IMAGE_QA_MIN_SCORE=0.72
# PAYAID_IMAGE_QA_REFINEMENT_ENABLED=true
# PAYAID_IMAGE_QA_REFINEMENT_STRENGTH=0.4
# Optional debug payload in non-prod by request body: { "qaDebug": true }

# Option D (self-hosted): ComfyUI
# USE_COMFYUI=false
# COMFYUI_URL="http://127.0.0.1:8188"
# COMFYUI_TXT2IMG_WORKFLOW_PATH="D:\\path\\to\\txt2img.payaid.json"

# --- AI Video generation (dynamic video worker) ---
# Point to a dedicated video worker endpoint (AnimateDiff / SVD / Kling-style backend).
# The endpoint should accept POST JSON with:
# { jobId, type:"video", prompt?, imageUrl?, durationSec?, aspectRatio?, tenantId?, options? }
# options can include: script, scenePlan, voiceoverText, referenceAudioUrl, lipSync, shotCount, fps, seed
# AI_VIDEO_QUEUE_URL="https://video-worker.yourdomain.com/generate"
# Optional shared secret header from dashboard -> worker:
# AI_VIDEO_QUEUE_SECRET=""
