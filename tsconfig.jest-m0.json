{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node", "jest"],
    "isolatedModules": true
  },
  "include": [
    "__tests__/m0/**/*.ts",
    "lib/ai-native/**/*.ts",
    "lib/lead-intelligence/**/*.ts",
    "apps/dashboard/app/api/v1/**/*.ts",
    "apps/dashboard/app/api/marketing/**/*.ts",
    "apps/dashboard/app/api/lead-intelligence/**/*.ts",
    "lib/middleware/**/*.ts",
    "lib/db/prisma.ts"
  ]
}
