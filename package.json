    "test:e2e:headed": "npm run verify:db && playwright test -c playwright.config.ts --headed",
    "test:e2e:route-health": "npm run verify:db && playwright test -c playwright.config.ts route-health --project chromium --reporter=list",
    "test:e2e:route-health:serial": "npm run verify:db && playwright test -c playwright.config.ts route-health --workers=1 --project chromium --reporter=list",
    "test:e2e:ui-scanner": "npm run verify:db && npm run fix:ui-scanner-spec && playwright test -c playwright.config.ts tests/ui-scanner-run.spec.ts",
    "test:e2e:ui-scanner-single": "npm run verify:db && playwright test -c playwright.config.ts tests/ui-scanner-single.spec.ts",
