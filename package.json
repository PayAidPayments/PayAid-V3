    "test:e2e:crm-audit": "cross-env PLAYWRIGHT_NO_WEB_SERVER=1 CRM_AUDIT_SKIP_PREFLIGHT=1 PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test -c playwright.crm-audit.config.ts",
