    "start:free-stack": "powershell -ExecutionPolicy Bypass -File scripts/start-free-stack.ps1",
    "test": "jest --passWithNoTests",
    "test:crm:tasks-filters": "node node_modules/jest/bin/jest.js --config jest.crm-closure.config.js --runInBand --watchAll=false --runTestsByPath lib/crm/__tests__/tasks-list-where.test.ts",
    "test:sales:proxy-canonical": "node node_modules/jest/bin/jest.js --runInBand --watchAll=false --runTestsByPath apps/dashboard/__tests__/proxy.test.ts",
    "test:crm:merge-key": "node node_modules/jest/bin/jest.js --config jest.crm-closure.config.js --runInBand --watchAll=false --runTestsByPath lib/crm/__tests__/contact-merge-key.test.ts",
    "test:crm:merge-guard": "node node_modules/jest/bin/jest.js --config jest.crm-closure.config.js --runInBand --watchAll=false --runTestsByPath lib/crm/__tests__/contact-merge-guard.test.ts",
    "test:crm:rbac": "node node_modules/jest/bin/jest.js --config jest.crm-closure.config.js --runInBand --watchAll=false --runTestsByPath lib/crm/__tests__/rbac.test.ts",
    "test:m0": "node node_modules/jest/bin/jest.js --config jest.m0.config.js --runInBand",
    "test:m2:smoke": "node node_modules/jest/bin/jest.js --config jest.m2.smoke.config.js --runInBand",
    "test:m3:smoke": "node node_modules/jest/bin/jest.js --config jest.m3.smoke.config.js --runInBand",
    "verify:dashboard": "npm run test:m0 && npm run lint -w dashboard",
