    "test:e2e:crm-day3-qa": "npm run verify:db && cross-env PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000 PLAYWRIGHT_NO_WEB_SERVER=1 playwright test -c playwright.config.ts tests/e2e/crm-day3-tasks-qa-smoke.spec.ts --project chromium --workers=1 --reporter=list",
    "test:e2e:cpq-workspace": "cross-env PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000 PLAYWRIGHT_NO_WEB_SERVER=1 playwright test -c playwright.config.ts tests/e2e/crm-cpq-workspace.spec.ts --project chromium --reporter=list",
    "release:gate:smoke": "node scripts/run-release-gate-suite.mjs",
    "release:gate:canonical-contract": "cross-env RELEASE_GATES=canonical-contract node scripts/run-release-gate-suite.mjs",
