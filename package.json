    "verify:inbound-pilot-smoke": "npx tsx scripts/verify-inbound-pilot-smoke.ts",
    "verify:inbound-pilot-smoke:local": "cross-env DATABASE_DIRECT_URL= DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public npx tsx scripts/verify-inbound-pilot-smoke.ts",
    "smoke:inbound-pilot": "cross-env PAYAID_CLI_SCRIPT=1 npx tsx scripts/smoke-inbound-pilot-integration.ts",
    "smoke:inbound-pilot:local": "cross-env DATABASE_DIRECT_URL= DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public PAYAID_CLI_SCRIPT=1 npx tsx scripts/smoke-inbound-pilot-integration.ts",
    "verify:db:local": "cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public tsx scripts/verify-database-connection-setup.ts",
    "check:vercel-env": "tsx scripts/check-vercel-env.ts",
    "check:postgrest": "tsx scripts/check-postgrest-status.ts",
    "check:deals": "npx tsx scripts/check-deals.ts",
    "dev": "npm run dev -w dashboard",
    "dev:fast": "npm run dev:fast -w dashboard",
    "dev:3002": "next dev -p 3002 --webpack",
    "dev:turbo": "node node_modules/turbo/bin/turbo dev --filter=dashboard",
    "dev:websocket": "tsx server/websocket-voice-server.ts",
    "dev:telephony": "tsx server/telephony-audio-stream.ts",
    "dev:all:3002": "npx concurrently \"npm run dev:3002\" \"npm run dev:websocket\"",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=5120 npm run build -w dashboard",
    "build:with-prisma": "node scripts/prisma-generate-with-retry.js && prisma migrate deploy && cross-env NODE_OPTIONS=--max-old-space-size=5120 npm run build -w dashboard",
    "build:typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=5120 npm run build -w dashboard",
    "build:with-db": "prisma generate && prisma db push --skip-generate --accept-data-loss && cross-env NODE_OPTIONS=--max-old-space-size=5120 npm run build -w dashboard",
    "start": "npm run start -w dashboard",
    "postinstall": "node scripts/prisma-generate-with-retry.js",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "db:generate": "cross-env PRISMA_GENERATE_STRICT=1 node scripts/prisma-generate-with-retry.js",
    "db:generate:loose": "node scripts/prisma-generate-with-retry.js",
    "db:push": "prisma db push",
    "db:push:local": "cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public node scripts/assert-local-db-url.mjs && cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public prisma db push --skip-generate",
    "db:push:local:skip-generate": "cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public node scripts/assert-local-db-url.mjs && cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public prisma db push --skip-generate --accept-data-loss",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:status:local": "cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public prisma migrate status",
    "db:migrate:deploy:local": "cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public prisma migrate deploy",
    "db:local:baseline-migrations": "node scripts/baseline-local-prisma-migrations.mjs",
    "db:local:fresh-from-schema": "npm run db:local:up && npm run db:local:wait && npm run db:push:local && npm run db:local:baseline-migrations && cross-env DATABASE_DIRECT_URL= DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public PAYAID_CLI_SCRIPT=1 npm run db:seed",
    "db:local:migrate": "npm run db:local:up && npm run db:migrate:deploy:local && npm run db:generate",
    "db:local:migrate:retry": "npm run db:local:up && powershell -ExecutionPolicy Bypass -Command \"Start-Sleep -Seconds 10\" && npm run db:migrate:deploy:local && npm run db:generate",
    "db:backfill-tenant-slugs": "npx tsx scripts/backfill-tenant-slugs.ts",
    "db:check-tables": "npx tsx scripts/check-missing-tables.ts",
    "db:migrate:vercel": "npx tsx scripts/run-migrations-vercel.ts",
    "db:studio": "prisma studio",
    "db:studio:prod": "cross-env NODE_ENV=production prisma studio",
    "db:studio:clean": "prisma studio --port 5556",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed-campaigns": "npx tsx prisma/seed-campaigns.ts",
    "db:seed-all": "npx tsx prisma/seed-all-sample-data.ts",
    "db:seed-news": "npx tsx prisma/seed-news-items.ts",
    "seed:demo-home-data": "npx tsx scripts/seed-demo-home-data.ts",
    "seed:demo-business": "npx tsx prisma/seeds/demo/run-demo-business-seed.ts",
    "seed:verify-demo-workforce": "npx tsx prisma/seeds/demo/verify-demo-workforce.ts",
    "seed:verify-demo-workforce:strict": "npx tsx prisma/seeds/demo/verify-demo-workforce.ts --strict",
    "seed:admin-users": "npx tsx prisma/seeds/seed-admin-users.ts",
    "seed:via-api": "npx tsx scripts/seed-via-api.ts",
    "seed:payaid-demo-agent": "npx tsx scripts/seed-payaid-payments-demo-agent.ts",
    "add:lead-sources": "npx tsx prisma/seeds/demo/add-lead-sources.ts",
    "validate:demo-data": "npx tsx prisma/seeds/demo/validate-demo-data.ts",
    "enable-all-modules": "npx tsx scripts/enable-all-modules.ts",
    "test:crm": "npx tsx scripts/test-crm-dashboard.ts",
    "test:vexyl": "npx tsx scripts/test-vexyl-tts.ts",
    "test:coqui": "npx tsx scripts/test-coqui-tts.ts",
    "type-check": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "type-check:quick": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit --skipLibCheck",
    "typecheck:dashboard": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --noEmit --pretty false -p apps/dashboard/tsconfig.typecheck.json",
    "ci:dashboard": "npm run test:m0 && npm run typecheck:dashboard",
    "check-before-push": "powershell -ExecutionPolicy Bypass -File scripts/check-before-push.ps1",
    "check-changed": "powershell -ExecutionPolicy Bypass -File scripts/check-changed-files.ps1",
    "verify-env": "npx tsx scripts/verify-env.ts",
    "check-vercel-logs": "powershell -ExecutionPolicy Bypass -File scripts/check-vercel-logs.ps1",
    "verify-env-and-logs": "powershell -ExecutionPolicy Bypass -File scripts/verify-env-and-logs.ps1",
