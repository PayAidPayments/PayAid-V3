    "test:e2e:show-report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "test:e2e:share": "npm run verify:db && cross-env NODE_OPTIONS=--max-old-space-size=8192 PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000 PLAYWRIGHT_JSON_REPORT=1 playwright test -c playwright.config.ts --workers=1 && npx tsx scripts/e2e-results-backup.ts && npx tsx scripts/e2e-results-to-markdown.ts",
    "test:e2e:share:localdb": "npm run db:local:up && npm run db:local:setup && npm run verify:db:local && npm run fix:ui-scanner-spec && cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public REDIS_URL=redis://127.0.0.1:6379 NODE_OPTIONS=--max-old-space-size=8192 PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000 PLAYWRIGHT_JSON_REPORT=1 playwright test -c playwright.config.ts --workers=1 && npx tsx scripts/e2e-results-backup.ts && npx tsx scripts/e2e-results-to-markdown.ts",
    "test:e2e:share:oom-safe": "npm run verify:db && cross-env NODE_OPTIONS=--max-old-space-size=8192 PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000 PLAYWRIGHT_JSON_REPORT=1 playwright test -c playwright.config.ts --workers=1 && npx tsx scripts/e2e-results-to-markdown.ts",
    "db:local:up": "docker compose -f docker-compose.local-db.yml up -d",
    "db:local:down": "docker compose -f docker-compose.local-db.yml down -v",
    "db:local:logs": "docker compose -f docker-compose.local-db.yml logs -f --tail=200",
    "db:local:wait": "cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public node scripts/wait-for-local-db.mjs",
    "db:local:sync": "npm run db:local:up && npm run db:local:wait && npm run db:migrate:deploy:local",
    "db:local:setup": "cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public prisma generate && cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public prisma db push && cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public npm run db:seed",
    "db:local:bootstrap": "npm run db:local:up && npm run db:local:wait && npm run db:push:local:skip-generate",
    "db:local:bootstrap:retry": "npm run db:local:up && npm run db:local:wait && powershell -ExecutionPolicy Bypass -Command \"Start-Sleep -Seconds 10\" && npm run db:push:local:skip-generate",
    "db:local:bootstrap:seed": "npm run db:local:bootstrap && cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public npm run db:seed",
    "test:e2e:ui-scanner:localdb": "npm run db:local:up && npm run db:local:setup && cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public REDIS_URL=redis://127.0.0.1:6379 PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000 npm run fix:ui-scanner-spec && playwright test -c playwright.config.ts tests/ui-scanner-run.spec.ts",
    "test:health": "npx tsx scripts/test-system-health.ts",
    "test:queue": "npx tsx scripts/test-job-queue.ts",
    "test:monitoring": "npx tsx scripts/test-monitoring.ts",
    "collect:m0:exit-evidence": "node scripts/collect-m0-exit-metrics-evidence.mjs",
    "collect:m2:staging-evidence": "node scripts/collect-m2-staging-evidence.mjs",
    "collect:m2:staging-evidence:fk": "cross-env M2_VALIDATE_CALL_FK=1 node scripts/collect-m2-staging-evidence.mjs",
    "check:crm-closure-env": "node scripts/check-crm-closure-env.mjs",
    "collect:crm-closure-blockers": "node scripts/run-crm-closure-blockers.mjs",
    "collect:crm-closure-blockers:tests-only": "cross-env CRM_CLOSURE_SKIP_AUTH=1 node scripts/run-crm-closure-blockers.mjs",
    "collect:crm-closure-blockers:auth-only": "cross-env CRM_CLOSURE_SKIP_TESTS=1 node scripts/run-crm-closure-blockers.mjs",
    "collect:crm-auth-baseline": "node scripts/run-crm-auth-baseline.mjs",
    "verify:email-prod-readiness": "node scripts/verify-email-prod-readiness.mjs",
    "verify:email-prod-readiness:local": "cross-env DATABASE_URL=postgresql://payaid:payaid@127.0.0.1:5433/payaid_v3?schema=public REDIS_URL=redis://127.0.0.1:6379 node scripts/verify-email-prod-readiness.mjs",
    "verify:email-go-live-precheck": "node scripts/run-email-go-live-precheck.mjs",
    "verify:email-go-live-gated-precheck": "node scripts/run-email-go-live-gated-precheck.mjs",
    "check:email-precheck-env": "node scripts/check-email-precheck-env.mjs",
    "capture:email-db-state": "node scripts/capture-email-db-state.mjs",
    "db:apply:email-ops-schema": "node scripts/apply-email-ops-schema.mjs",
    "bench:api-timing": "node scripts/bench-api-timing.mjs",
    "bench:api-timing:artifact": "cross-env BENCH_WRITE_ARTIFACT=1 node scripts/bench-api-timing.mjs",
    "bench:api-timing:artifact:baseline": "cross-env BENCH_WRITE_ARTIFACT=1 BENCH_ARTIFACT_ROLE=baseline node scripts/bench-api-timing.mjs",
    "bench:api-timing:artifact:candidate": "cross-env BENCH_WRITE_ARTIFACT=1 BENCH_ARTIFACT_ROLE=candidate node scripts/bench-api-timing.mjs",
    "bench:api-timing:artifact:pair": "node scripts/capture-api-timing-pair.mjs",
    "bench:api-timing:artifact:name": "node scripts/generate-api-timing-artifact-name.mjs",
    "bench:api-timing:compare": "cross-env BENCH_COMPARE=1 node scripts/bench-api-timing.mjs",
    "bench:api-timing:gate": "cross-env BENCH_COMPARE=1 BENCH_FAIL_ON_REGRESSION=1 node scripts/bench-api-timing.mjs",
    "bench:api-timing:pipeline": "node scripts/run-api-timing-pipeline.mjs",
    "bench:api-timing:verdict": "node scripts/print-api-timing-verdict.mjs",
    "db:apply:specialist-activity-migration": "node scripts/apply-specialist-activity-migration.mjs",
    "verify:specialist-activity-migration": "node scripts/verify-specialist-activity-migration.mjs",
    "verify:specialist-activity-ui-status": "node scripts/verify-specialist-activity-ui-status.mjs",
    "nightly:evidence:archive": "node scripts/run-nightly-evidence-archive.mjs",
    "scan:permission-posture": "node scripts/scan-permission-posture.mjs",
    "init:m1:exit-evidence": "node scripts/init-m1-exit-evidence.mjs",
    "validate:m1:exit-evidence": "node scripts/validate-m1-exit-evidence.mjs",
    "validate:m1:exit-evidence:strict": "node scripts/validate-m1-exit-evidence.mjs --strict true",
    "validate:m1:exit-evidence:ready": "node scripts/validate-m1-exit-evidence.mjs --strict true --min-percent 90",
    "validate:m1:exit-evidence:ready:critical": "node scripts/validate-m1-exit-evidence.mjs --strict true --min-percent 90 --require-critical true",
