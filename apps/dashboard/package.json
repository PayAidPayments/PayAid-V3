{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-server.cjs",
    "dev:fast": "node ../../node_modules/cross-env/dist/bin/cross-env.js NODE_OPTIONS=--max-old-space-size=6144 SKIP_EXTERNAL_PREFLIGHT=1 SKIP_FREE_PORT=1 NEXT_DEV_HOST=127.0.0.1 PAYAID_DISABLE_OPTIMIZE_PACKAGE_IMPORTS=1 node scripts/dev-server.cjs",
    "build": "node scripts/next-build.cjs",
    "build:turbo": "next build --turbopack",
    "typecheck": "tsc --noEmit --pretty false",
    "bench:crm-stats": "node scripts/bench-crm-stats.mjs",
    "start": "next start -p 3000",
    "lint": "node ../../node_modules/cross-env/dist/bin/cross-env.js ESLINT_USE_FLAT_CONFIG=true eslint ."
  },
  "dependencies": {
    "@tiptap/react": "^2.26.3",
    "@tiptap/starter-kit": "^2.26.3",
    "@payaid/ai": "file:../../packages/ai",
    "@payaid/db": "file:../../packages/db",
    "@payaid/social": "file:../../packages/social",
    "@tanstack/react-query": "^5.100.5",
    "@upstash/redis": "^1.35.6",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.23.24",
    "graphql": "^16.11.0",
    "groq-sdk": "^0.33.0",
    "ioredis": "^5.8.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.17.2",
    "razorpay": "^2.9.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.6.0",
    "tailwind-merge": "^2.4.0",
    "twilio": "^5.11.2",
